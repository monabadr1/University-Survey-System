@page "/admin/surveys/addSurvey"
@attribute [Authorize(Roles = "Admin")]
@using Shared
@inject Front.Consumer.SurveyConsumer SurveyConsumer
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Authorization

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-9 col-xl-8">
            <div class="card shadow-sm border-0 survey-card">
                <div class="card-body p-4 p-md-5">

                    <div class="d-flex align-items-start justify-content-between mb-4">
                        <div>
                            <h4 class="mb-1">Add Survey</h4>
                            <div class="text-muted small">Create a new survey and define its settings.</div>
                        </div>

                        <button type="button" class="btn btn-light btn-sm" @onclick="Back">
                            Back
                        </button>
                    </div>

                    <EditForm Model="model" OnValidSubmit="Save">
                        <DataAnnotationsValidator />

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Title</label>
                                <InputText class="form-control" @bind-Value="model.Title" placeholder="e.g. Customer Satisfaction Survey" />
                                <ValidationMessage For="@(() => model.Title)" />
                            </div>

                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <InputTextArea class="form-control" rows="4" @bind-Value="model.Description" placeholder="Write a short description..." />
                                <ValidationMessage For="@(() => model.Description)" />
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label">Target Group</label>
                                <InputSelect class="form-select" @bind-Value="model.TargetGroups">
                                    <option value="@TargetGroups.Student">Student</option>
                                    <option value="@TargetGroups.Employee">Employee</option>
                                </InputSelect>
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">Start Date</label>
                                <InputDate class="form-control" @bind-Value="model.StartDate" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">End Date</label>
                                <InputDate class="form-control" @bind-Value="model.EndDate" />
                            </div>

                            <div class="col-12">
                                <div class="p-3 rounded-3 bg-light">
                                    <div class="form-check mb-2">
                                        <InputCheckbox class="form-check-input" @bind-Value="model.Allowmultiblesubmission" />
                                        <label class="form-check-label">Allow multiple submissions</label>
                                    </div>

                                    <div class="form-check">
                                        <InputCheckbox class="form-check-input" @bind-Value="model.IsAnonymous" />
                                        <label class="form-check-label">Anonymous</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button class="btn btn-custom px-4" type="submit">
                                Save
                            </button>
                            <button type="button" class="btn btn-outline-secondary px-4" @onclick="Back">
                                Cancel
                            </button>
                        </div>

                        <!-- لو تحبي تظهر Summary تحت -->
                        <ValidationSummary class="text-danger mt-3" />
                    </EditForm>

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private SurveyDto model = new()
    {
        StartDate = DateTime.Today,
        EndDate = DateTime.Today.AddDays(7),
        TargetGroups = TargetGroups.Student
    };

    private async Task Save()
    {
        var id = await SurveyConsumer.CreateSurveyAsync(model);
        Nav.NavigateTo($"/admin/surveys/{id}/questions");
    }

    private void Back() => Nav.NavigateTo("/admin/surveys");
}
