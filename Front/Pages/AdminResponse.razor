@page "/admin/response"
@attribute [Authorize(Roles = "Admin")]

@inject Front.Consumer.UserConsumer UserConsumer
@inject NavigationManager Nav
@using Shared
@using Microsoft.AspNetCore.Authorization

<div class="d-flex align-items-start justify-content-between mb-3">
    <div>
        <h4 class="mb-1">Responses</h4>
        <div class="text-muted small">Browse submitted responses and open details.</div>
    </div>

    <div class="response-search">
        <input class="form-control" placeholder="Search by title, response id, user id..."
               @bind="search" @bind:event="oninput" />
    </div>
</div>

@if (loading)
{
    <div class="alert alert-secondary">Loading...</div>
}
else if (FilteredResponses.Count == 0)
{
    <div class="alert alert-info">No responses found.</div>
}
else
{
    <div class="row g-3">
        @foreach (var r in FilteredResponses)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm h-100 response-card" role="button"
                     @onclick="() => OpenResponse(r.ResponseId)">

                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="pe-2">
                                <div class="fw-semibold text-truncate" style="max-width: 240px;">
                                    @(string.IsNullOrWhiteSpace(r.Title) ? "Response" : r.Title)
                                </div>
                                <div class="text-muted small mt-1">
                                    #@r.ResponseId • User @r.First_name
                                </div>
                            </div>

                            <span class="badge bg-success badge-pill">Submitted</span>
                        </div>

                        <div class="mt-3 text-muted small">
                            Submitted at: @r.SubmittedAt.ToString("yyyy-MM-dd hh:mm tt")
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
                        <button class="btn btn-sm btn-outline-dark w-100" type="button"
                                @onclick:stopPropagation="true"
                                @onclick="() => OpenResponse(r.ResponseId)">
                            Open details
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private bool loading = true;
    private string search = "";
    private List<ResponseDto> response = new();

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        response = await UserConsumer.AllResponse();
        loading = false;
    }

    private List<ResponseDto> FilteredResponses =>
        string.IsNullOrWhiteSpace(search)
            ? response
            : response.Where(r =>
                    (r.Title ?? "").Contains(search, StringComparison.OrdinalIgnoreCase)
                    || r.ResponseId.ToString().Contains(search, StringComparison.OrdinalIgnoreCase)
                    || r.UserId.ToString().Contains(search, StringComparison.OrdinalIgnoreCase)
              ).ToList();

    private void OpenResponse(int responseId)
        => Nav.NavigateTo($"/response/{responseId}");
}
