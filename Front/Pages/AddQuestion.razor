@page "/admin/surveys/{SurveyId:int}/questions"
@attribute [Authorize(Roles = "Admin")]
@using Shared
@using Microsoft.AspNetCore.Authorization
@inject Front.Consumer.SurveyConsumer SurveyConsumer
@inject NavigationManager Nav

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-9 col-xl-8">
            <div class="card shadow-sm border-0 survey-card">
                <div class="card-body p-4 p-md-5">

                    <!-- Header -->
                    <div class="d-flex align-items-start justify-content-between mb-4">
                        <div>
                            <h4 class="mb-1">Survey Questions</h4>
                            <div class="text-muted small">SurveyId: @SurveyId</div>
                        </div>

                        <button type="button" class="btn btn-light btn-sm" @onclick="BackToList">
                            Back
                        </button>
                    </div>

                    <!-- Add Question Card -->
                    <div class="p-3 p-md-4 rounded-3 bg-light mb-4">
                        <h6 class="mb-3">Add Question</h6>

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Question Text</label>
                                <InputText class="form-control" @bind-Value="qModel.questiontext" placeholder="Write your question..." />
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label">Type</label>
                                <InputSelect class="form-select" @bind-Value="qModel.Type">
                                    <option value="@QuestionType.Text">Text</option>
                                    <option value="@QuestionType.SingleChoice">Single Choice</option>
                                    <option value="@QuestionType.MultipleChoice">Multiple Choice</option>
                                </InputSelect>
                            </div>

                            <div class="col-12 col-md-6 d-flex align-items-end">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="qModel.isrquired" />
                                    <label class="form-check-label">Required</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-3">
                            <button type="button" class="btn btn-custom px-4" @onclick="AddQuestions">
                                Add Question
                            </button>
                        </div>
                    </div>

                    <!-- Add Option Card (only after adding a choice question) -->
                    @if (lastQuestionId > 0 && (qModel.Type == QuestionType.SingleChoice || qModel.Type == QuestionType.MultipleChoice))
                    {
                        <div class="p-3 p-md-4 rounded-3 bg-light mb-4">
                            <div class="d-flex align-items-start justify-content-between mb-2">
                                <div>
                                    <h6 class="mb-1">Add Options</h6>
                                    <div class="text-muted small">QuestionId: @lastQuestionId</div>
                                </div>
                            </div>

                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label">Option Text</label>
                                    <InputText class="form-control" @bind-Value="optModel.Text" placeholder="e.g. Yes" />
                                </div>
                            </div>

                            <div class="d-flex gap-2 mt-3">
                                <button type="button" class="btn btn-outline-primary px-4" @onclick="AddOption">
                                    Add Option
                                </button>
                            </div>
                        </div>
                    }

                    <!-- Actions -->
                    <div class="d-flex gap-2 mb-4">
                        <button type="button" class="btn btn-success px-4" @onclick="Publish">
                            Publish Survey
                        </button>
                        <button type="button" class="btn btn-outline-secondary px-4" @onclick="BackToList">
                            Back to Surveys
                        </button>
                    </div>

                    <hr class="my-4" />

                    <!-- Current Questions -->
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h6 class="mb-0">Current Questions</h6>
                        @if (loading)
                        {
                            <span class="text-muted small">Loading...</span>
                        }
                    </div>

                    @if (!loading)
                    {
                        if (questions.Count == 0)
                        {
                            <div class="text-muted">No questions yet.</div>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var q in questions)
                                {
                                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                        <div>
                                            <div class="fw-semibold">@q.questiontext</div>
                                            <div class="text-muted small">@q.Type</div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int SurveyId { get; set; }

    private bool loading = true;
    private List<QuestionDto> questions = new();

    private CreateQuestionDto qModel = new() { Type = QuestionType.Text, isrquired = false };
    private QuestionOptionDto optModel = new() { Text = "" };

    private int lastQuestionId = 0;

    protected override async Task OnParametersSetAsync()
    {
        await ReloadQuestions();
    }

    private async Task ReloadQuestions()
    {
        loading = true;
        questions = await SurveyConsumer.GetSurveyQuestionAsync(SurveyId);
        loading = false;
    }

    private async Task AddQuestions()
    {
        lastQuestionId = await SurveyConsumer.AddQuestionAsync(SurveyId, qModel);

        optModel = new QuestionOptionDto { Text = "" };

        await ReloadQuestions();
    }

    private async Task AddOption()
    {
        if (lastQuestionId <= 0) return;

        optModel.QuestionId = lastQuestionId;
        await SurveyConsumer.AddOptionAsync(lastQuestionId, optModel);

        optModel = new QuestionOptionDto { Text = "" };
        await ReloadQuestions();
    }

    private async Task Publish()
    {
        await SurveyConsumer.PublishSurveyAsync(SurveyId);
        Nav.NavigateTo("/admin/surveys");
    }

    private void BackToList() => Nav.NavigateTo("/admin/surveys");
}
